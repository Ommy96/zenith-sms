# ---------------------------------------------------------------------------
# Zenith environment variables
# Copy to `.env` (gitignored) and fill in values. Secrets are NOT committed.
# ---------------------------------------------------------------------------

# Lovable Cloud / Supabase (auto-injected in Lovable preview & deploys)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Observability — optional
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# ---------------------------------------------------------------------------
# Edge function secrets (set via Lovable Cloud secrets, not this file)
# ---------------------------------------------------------------------------
# EDGE_SENTRY_DSN
# VAPID_PUBLIC_KEY          # web-push public key, exposed by push-vapid-key fn
# VAPID_PRIVATE_KEY         # web-push private key, used only by push-send fn
# VAPID_SUBJECT             # mailto:admin@yourschool.example
# MPESA_CONSUMER_KEY / MPESA_CONSUMER_SECRET / MPESA_PASSKEY  (per tenant)
# OPENAI_API_KEY            # optional, only if not on Lovable AI Gateway